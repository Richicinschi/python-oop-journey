# =============================================================================
# Production Environment Configuration Template
# =============================================================================
# Copy this file to .env.production and fill in the actual values
# WARNING: Never commit .env.production to version control!
# =============================================================================

# =============================================================================
# Application Settings
# =============================================================================

# Environment: production
ENVIRONMENT=production

# Debug mode (MUST be false in production!)
DEBUG=false

# Secret key for JWT signing and session encryption
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars

# =============================================================================
# Domain Configuration
# =============================================================================

# Primary domain
DOMAIN=oopjourney.com

# Staging domain
STAGING_DOMAIN=staging.oopjourney.com

# =============================================================================
# Frontend (Next.js)
# =============================================================================

# Public API URL (used by browser)
NEXT_PUBLIC_API_URL=https://api.oopjourney.com

# Public App URL (used for redirects and links)
NEXT_PUBLIC_APP_URL=https://oopjourney.com

# =============================================================================
# Backend (FastAPI)
# =============================================================================

# Internal API URL (used for server-side requests)
API_INTERNAL_URL=http://api:8000

# =============================================================================
# Database (PostgreSQL)
# =============================================================================

POSTGRES_USER=oopjourney
# Generate strong password with: openssl rand -base64 32
POSTGRES_PASSWORD=change-this-to-a-strong-password
POSTGRES_DB=oopjourney_production

# Full database URL (overrides individual settings)
DATABASE_URL=postgresql://oopjourney:change-this-to-a-strong-password@db:5432/oopjourney_production

# Connection pool settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# =============================================================================
# Cache (Redis)
# =============================================================================

REDIS_URL=redis://redis:6379/0

# =============================================================================
# JWT Settings
# =============================================================================

# Use same as SECRET_KEY or generate separate one
JWT_SECRET=change-this-to-a-random-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=7
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# =============================================================================
# Auth Settings
# =============================================================================

# Magic Link Settings
MAGIC_LINK_EXPIRE_MINUTES=15
MAGIC_LINK_BASE_URL=https://oopjourney.com

# =============================================================================
# Email Configuration (Choose one)
# =============================================================================

# Option 1: SMTP
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
FROM_EMAIL=noreply@oopjourney.com
FROM_NAME="OOP Journey"

# Option 2: SendGrid (preferred)
SENDGRID_API_KEY=SG.xxx.yyy

# =============================================================================
# Sandbox Configuration
# =============================================================================

SANDBOX_DOCKER_IMAGE=oopjourney-sandbox:latest
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY_LIMIT_MB=256
SANDBOX_CPU_LIMIT=0.5

# Docker socket path
DOCKER_SOCKET=/var/run/docker.sock

# =============================================================================
# Monitoring & Error Tracking
# =============================================================================

# Sentry DSN (get from sentry.io)
SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# Sentry environment
SENTRY_ENVIRONMENT=production

# Log level: debug | info | warning | error | critical
LOG_LEVEL=info

# =============================================================================
# Analytics
# =============================================================================

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Plausible Analytics (privacy-friendly alternative)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=oopjourney.com

# Mixpanel (optional)
MIXPANEL_TOKEN=your-mixpanel-token

# =============================================================================
# Feature Flags
# =============================================================================

# Enable AI hints
FEATURE_AI_HINTS=true

# Enable community features
FEATURE_COMMUNITY=false

# Enable gamification
FEATURE_GAMIFICATION=true

# Enable real-time collaboration
FEATURE_COLLABORATION=false

# =============================================================================
# SSL/TLS (for manual certificate management)
# =============================================================================

# Only needed if not using Let's Encrypt
# SSL_CERT_PATH=/etc/ssl/certs/oopjourney.crt
# SSL_KEY_PATH=/etc/ssl/private/oopjourney.key

# =============================================================================
# Backup Configuration
# =============================================================================

# AWS S3 for backups (optional)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=oopjourney-backups
AWS_S3_REGION=us-east-1

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# =============================================================================
# Security Settings
# =============================================================================

# CORS origins (comma-separated)
CORS_ORIGINS=https://oopjourney.com,https://www.oopjourney.com

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# Grafana (Monitoring)
# =============================================================================

GRAFANA_ADMIN_PASSWORD=change-this-to-a-strong-password

# =============================================================================
# Health Check Token (for external monitoring)
# =============================================================================

HEALTH_CHECK_TOKEN=generate-a-random-token-for-health-checks
