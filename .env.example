# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file to .env for development or .env.production for production
#
# WARNING: Never commit .env or .env.production files to version control!
# =============================================================================

# =============================================================================
# Application Settings
# =============================================================================

# Environment: development | staging | production
ENVIRONMENT=development

# Debug mode (disable in production!)
DEBUG=true

# Secret key for JWT signing and session encryption
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production

# =============================================================================
# Frontend (Next.js)
# =============================================================================

# Public API URL (used by browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public App URL (used for redirects and links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Backend (FastAPI)
# =============================================================================

# Internal API URL (used for server-side requests)
API_INTERNAL_URL=http://api:8000

# =============================================================================
# Database (PostgreSQL)
# =============================================================================

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=oopjourney

# Full database URL (overrides individual settings)
DATABASE_URL=postgresql://postgres:postgres@db:5432/oopjourney

# Connection pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# =============================================================================
# Cache (Redis)
# =============================================================================

REDIS_URL=redis://redis:6379

# =============================================================================
# Sandbox Configuration
# =============================================================================

# Docker image name for sandbox
SANDBOX_DOCKER_IMAGE=oopjourney-sandbox:latest

# Execution timeout in seconds
SANDBOX_TIMEOUT_SECONDS=30

# Memory limit in MB
SANDBOX_MEMORY_LIMIT_MB=256

# CPU limit (cores)
SANDBOX_CPU_LIMIT=0.5

# =============================================================================
# Content / Curriculum
# =============================================================================

# Path to curriculum content
CURRICULUM_PATH=./python-oop-journey-v2

# =============================================================================
# Auth Settings
# =============================================================================

# JWT Settings
# Secret key for JWT signing (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=7
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Magic Link Settings
MAGIC_LINK_EXPIRE_MINUTES=15
MAGIC_LINK_BASE_URL=http://localhost:3000

# =============================================================================
# Email Configuration (for magic link auth)
# =============================================================================

# Option 1: SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@oopjourney.com

# Option 2: SendGrid (preferred for production)
# SENDGRID_API_KEY=SG.xxx

# =============================================================================
# Legacy: Token expiration (kept for backward compatibility)
# =============================================================================
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Analytics (optional)
# NEXT_PUBLIC_ANALYTICS_ID=

# Error tracking (optional)
# SENTRY_DSN=

# =============================================================================
# Production Settings
# =============================================================================
# Uncomment and configure these for production deployment

# SSL/TLS
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# Domain
# DOMAIN=your-domain.com

# Docker socket path (for sandbox spawning)
# DOCKER_SOCKET=/var/run/docker.sock

# =============================================================================
# Development Settings
# =============================================================================
# These only apply to development environment

# Hot reload for FastAPI
UVICORN_RELOAD=true

# Log level: debug | info | warning | error
LOG_LEVEL=debug
