# Copy this to .env and fill in your values

# Application
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production-min-32-chars

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/oop_journey

# Redis
REDIS_URL=redis://localhost:6379/0

# Docker
DOCKER_HOST=unix:///var/run/docker.sock
SANDBOX_IMAGE=oop-journey-sandbox:latest

# Code Execution
DOCKER_TIMEOUT=30
MAX_CODE_LENGTH=10000

# Security - Add your production frontend URL for deployment
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://python-oop-journey.onrender.com

# =============================================================================
# Email Configuration (for magic link auth)
# =============================================================================

# Option 1: SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@oopjourney.com

# Option 2: SendGrid (preferred for production)
SENDGRID_API_KEY=

# =============================================================================
# JWT & Authentication Settings
# =============================================================================

JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=7
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Magic Link Settings
MAGIC_LINK_EXPIRE_MINUTES=15
MAGIC_LINK_BASE_URL=http://localhost:3000

# Legacy (kept for backward compatibility)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Logging
LOG_LEVEL=INFO

# =============================================================================
# AI Integration (OpenAI/Anthropic)
# =============================================================================

# OpenAI API Key (required for AI hints)
OPENAI_API_KEY=sk-...

# Anthropic API Key (optional, for Claude models)
ANTHROPIC_API_KEY=

# AI Model Configuration
AI_HINT_MODEL=gpt-4o-mini
AI_REVIEW_MODEL=gpt-4o
AI_RATE_LIMIT_PER_HOUR=10
AI_CACHE_TTL_HOURS=24
